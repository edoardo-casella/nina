# Archivio originale del kit e file locali
files.zip
.claude/settings.local.json

# Sorgenti con dati personali (nomi completi, IBAN, voli): MAI nel repo pubblico
data/*.xlsx
data/*.xls
data/*.local.*

# Foto originali dello skipper (59 MB, RAW inclusi): nel repo vanno solo le
# versioni web ridimensionate in site/skipper/img/ e site/crew/img/
data/Skipper Images/

# Foto per viaggio (upload locale, una cartella per viaggio, pre-riempita dalle
# foto del sito): restano LOCALI, nel repo vanno solo le versioni in site/trips/img/
data/Viaggi/

# Liste equipaggio e documenti personali (nomi completi, passaporti, DOB):
# MAI nel repo pubblico. Nel sito vanno solo iniziali e foto ridotte.
data/Crewlists/
data/*.pdf
data/*.docx
data/*.doc

# Intermedio di build (foto per persona, prodotto da build_trips.py e letto da
# build_crew.py): i dati finali finiscono in site/data/crew.json e trips.json
data/photo-tags.json

# Sorgenti e intermedi delle mappe-rotta (2011–2024): nel repo vanno solo i PNG
# renderizzati in site/trips/routes/ e gli script render_routes.py / merge_percorsi.py.
# Le tracce GPS grezze (KML/KMZ dei viaggi passati) e la basemap Natural Earth
# restano LOCALI. NB: le rotte 2026 data/percorso-hotpoints.kml e data/rotte-nina.kml
# sono tracciate a parte e non rientrano qui.
data/route-images/
data/geo/
data/Percorsi Google Earth/
data/Tutti i viaggi.kml
data/Tutti i viaggi.kmz
data/Viaggi in barca (2011-2024).kml

